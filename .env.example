# Salin file ini menjadi .env untuk development lokal
# Di Railway, set variabel-variabel ini langsung di tab Variables

# ── Django ────────────────────────────────────────────────────────────────────
# Generate SECRET_KEY baru:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=ganti-dengan-secret-key-yang-panjang-dan-random

DEBUG=False

# Isi dengan domain Railway kamu (boleh dikosongkan, .railway.app sudah otomatis diterima)
ALLOWED_HOSTS=web-production-xxxx.up.railway.app

# ── Database ──────────────────────────────────────────────────────────────────
# Di Railway: pakai DATABASE_URL yang di-inject otomatis dari service PostgreSQL
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Untuk development lokal (tanpa DATABASE_URL):
POSTGRES_DB=veloura_db
POSTGRES_USER=veloura_user
POSTGRES_PASSWORD=ganti-dengan-password-kuat
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL frontend yang sudah di-deploy (Vercel, Netlify, dll)
CORS_ALLOWED_ORIGINS=http://localhost:5173
