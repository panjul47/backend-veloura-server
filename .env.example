# Salin file ini menjadi .env dan isi nilainya
# Generate SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-domain.railway.app,your-domain.onrender.com

# ── Opsi 1: Render / Supabase (pakai DATABASE_URL) ──────────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname

# ── Opsi 2: Railway (pakai variabel terpisah) ────────────────────────────────
# POSTGRES_DB=veloura_db
# POSTGRES_USER=veloura_user
# POSTGRES_PASSWORD=your-db-password
# POSTGRES_HOST=your-db-host
# POSTGRES_PORT=5432

CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
